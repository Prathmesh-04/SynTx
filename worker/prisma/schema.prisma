generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Submission{
  id    Int @id @default(autoincrement())
  language        String
  sourceCode      String
  status          String
  input           String?
  output          String?
  time            String?
  memory          String?
  compile_output  String?
  message         String?

  userId          String
  user          User @relation(fields: [userId], references: [userId])
}

model User {
  userId     String       @id
  userName   String       @unique
  email      String       @unique
  password   String
  Submission Submission[]
}

